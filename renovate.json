{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":timezone(Asia/Tokyo)"],
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "description": "Open a PR immediately whenever a @dotmon package is released",
      "matchPackageNames": ["@dotmon/**"],
      "groupName": "dotmon packages",
      "schedule": ["at any time"],
      "prPriority": 10
    },
    {
      "description": "Batch all other dependency updates into one weekly PR",
      "matchPackageNames": ["!@dotmon/**"],
      "groupName": "weekly dependencies",
      "schedule": ["before 9am on monday"]
    }
  ]
}
